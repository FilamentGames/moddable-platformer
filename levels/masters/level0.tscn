[node name="SpecialCoin" type="Area2D" parent="SpecialCoins" unique_id=585640772 instance=ExtResource("9_16axh")]
editor_description = "Special coins are ignored when calculating the total number of coins that must be collected to win, though collecting one still counts towards that goal.

The only difference compared to coin.tscn is that special_coin.tscn is not in the \"coins\" group.

Use this scene for optional coins to the level, such as coins which can only be accessed by enabling new player abilitiies."
